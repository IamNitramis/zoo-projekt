# =========================
# 1. CLion a JetBrains IDE
# =========================
# Skryje veškeré lokální nastavení editoru (včetně tvého .iml souboru)
.idea/
*.iml
# CLion si ve výchozím stavu tvoří složky pro build (např. cmake-build-debug)
cmake-build-*/

# =========================
# 2. CMake a Build systémy
# =========================
# Skryje dočasné soubory, které CMake tvoří při přípravě kompilace
build/
CMakeCache.txt
CMakeFiles/
CMakeScripts/
Makefile
cmake_install.cmake
install_manifest.txt
compile_commands.json

# =========================
# 3. C++ kompiláty a binárky
# =========================
# Objektové soubory (mezikroky kompilace)
*.o
*.obj
# Dynamické a statické knihovny
*.so
*.dylib
*.dll
*.a
*.lib
# Spustitelné soubory
*.exe
*.out
*.app

# =========================
# 4. Soubory operačních systémů
# =========================
# Zabrání nahrávání neviditelných systémových souborů (Mac / Windows)
.DS_Store
Thumbs.db